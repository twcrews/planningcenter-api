{
  "AppSettings": {
    "OutputDirectory": "../Crews.PlanningCenter.Api/Definitions",
    "PlanningCenterClient": {
      "BaseAddress": "https://api.planningcenteronline.com/"
    },
    "DocumentationBuilder": {
      "ConcurrentConnections": 10,
      "ExcludedVertices": [
        { "Product": "people", "Version": null, "Vertex": "birthday_people" },
        { "Product": "people", "Version": null, "Vertex": "organization_statistics" }
      ],
      "EdgeTypeOverrides": [
        {
          "Product": "services",
          "Version": null,
          "Vertex": "organization",
          "Edge": "plans",
          "Type": "plan"
        }
      ],
      "CollectionOverrides": [
        {
          "Product": "people",
          "Version": null,
          "Vertex": "organization",
          "Edge": "stats",
          "IsCollection": false
        },
        {
          "Product": "people",
          "Version": null,
          "Vertex": "organization",
          "Edge": "birthday_people",
          "IsCollection": false
        }
      ]
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "System": "Warning"
    }
  }
}
